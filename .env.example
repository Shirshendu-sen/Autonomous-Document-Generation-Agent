# one of: groq | ollama | mock
LLM_PROVIDER=mock

# --- Groq (free tier: https://console.groq.com) -----------------------------
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Ollama (fully local: https://ollama.com) --------------------------------
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3

# --- Agent behaviour ----------------------------------------------------------
MAX_REFLECTION_ROUNDS=2
LLM_MAX_RETRIES=4
REQUEST_TIMEOUT_SECONDS=30
# Max concurrent section-drafting LLM calls. Groq free-tier keys are commonly
# capped around 6000 tokens/minute, and a single multi-section document can
# use most of that on its own -- keep this at 1-2 (verified empirically) so
# consecutive documents don't burst past the limit and 429 each other out.
LLM_MAX_CONCURRENCY=1
